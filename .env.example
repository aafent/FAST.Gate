# FAST.Gate — environment secrets
# Copy to .env — never commit .env

# ── M2M app credentials (for token validation and management API calls) ────────
# Create a Machine-to-Machine app in Logto named "FAST.Gate Service"
Gate__Identity__Logto__ServiceClientId=
Gate__Identity__Logto__ServiceClientSecret=

# ── Traditional Web app credentials (for SSO authorization code flow) ─────────
# Create a Traditional Web app in Logto named "FAST.Gate Web"
# Register your redirect URIs under this app
Gate__Identity__Logto__WebClientId=
Gate__Identity__Logto__WebClientSecret=

# ── Redirect URI registered in Logto under the Traditional Web app ─────────────
Gate__Identity__Logto__ServiceRedirectUri=https://gate.fast.internal/auth/callback

# ── SSO allowed redirect URIs (one per FAST application) ──────────────────────
Gate__Sso__AllowedRedirectUris__0=https://your-app.fast.internal/auth/callback
