@page "/"
@inject FastAuthStateProvider AuthState

<PageTitle>Dashboard — FAST.Gate Admin</PageTitle>

<div class="row g-3 mb-4">
    <div class="col-12">
        <h5 class="fw-semibold mb-0">
            <i class="bi bi-grid text-primary me-2"></i>Dashboard
        </h5>
        <p class="text-muted small mt-1 mb-0">
            Welcome back, <strong>@AuthState.CurrentAuth?.User?.FirstName</strong>.
            Your session expires at @AuthState.CurrentAuth?.ExpiresAt?.ToLocalTime().ToString("HH:mm:ss").
        </p>
    </div>
</div>

<div class="row g-3">

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-primary-subtle text-primary">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div>
                    <div class="stat-value">@(AuthState.CurrentAuth?.User?.LoginName ?? "—")</div>
                    <div class="stat-label">Logged in as</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-success-subtle text-success">
                    <i class="bi bi-shield-fill-check"></i>
                </div>
                <div>
                    <div class="stat-value">@(AuthState.CurrentAuth?.User?.Roles.Count ?? 0)</div>
                    <div class="stat-label">Roles assigned</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-info-subtle text-info">
                    <i class="bi bi-key-fill"></i>
                </div>
                <div>
                    <div class="stat-value">@TokenPreview</div>
                    <div class="stat-label">Access token</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon @(HasRefreshToken ? "bg-warning-subtle text-warning" : "bg-secondary-subtle text-secondary")">
                    <i class="bi bi-arrow-repeat"></i>
                </div>
                <div>
                    <div class="stat-value">@(HasRefreshToken ? "Available" : "None")</div>
                    <div class="stat-label">Refresh token</div>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="row g-3 mt-1">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header py-2">
                <span class="small fw-semibold">Quick Actions</span>
            </div>
            <div class="card-body d-flex flex-wrap gap-2 p-3">
                <a href="test/validate" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-patch-check me-1"></i>Validate Token
                </a>
                <a href="test/refresh" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh Token
                </a>
                <a href="test/me" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-person-badge me-1"></i>Get /me
                </a>
                <a href="system/health" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-heart-pulse me-1"></i>Health Check
                </a>
                <a href="user/roles" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-shield-check me-1"></i>View Roles
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    private string TokenPreview =>
        AuthState.CurrentAuth?.IdpAccessToken is { Length: > 12 } t
            ? $"{t[..8]}…" : "—";

    private bool HasRefreshToken =>
        !string.IsNullOrEmpty(AuthState.CurrentAuth?.IdpRefreshToken);
}
