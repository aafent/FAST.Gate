<div class="card applet-card shadow-sm h-100">
    <div class="card-header d-flex align-items-center gap-2 py-2 px-3">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <i class="bi @Icon text-primary"></i>
        }
        <span class="fw-semibold small">@Title</span>
        @if (!string.IsNullOrEmpty(Badge))
        {
            <span class="badge @BadgeClass ms-auto">@Badge</span>
        }
    </div>
    <div class="card-body p-3">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public string        Title        { get; set; } = "";
    [Parameter] public string?       Icon         { get; set; }
    [Parameter] public string?       Badge        { get; set; }
    [Parameter] public string        BadgeClass   { get; set; } = "bg-secondary";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
