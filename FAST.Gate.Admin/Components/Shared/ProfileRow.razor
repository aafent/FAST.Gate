<tr>
    <td class="px-3 py-2 text-muted small fw-medium" style="width:140px;">@Label</td>
    <td class="px-3 py-2 small @(Mono ? "font-mono" : "")">@Value</td>
</tr>

@code {
    [Parameter] public string  Label { get; set; } = "";
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool    Mono  { get; set; }
}
