{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "FastGate": {
    "GateBaseUrl": "http://localhost:5044",
    "SsoRedirectUri": "https://localhost:7002/auth/callback",
    "TokenRefreshBufferSeconds": 60,
    "TimeoutMs": 10000,
    "PropagateCorrelationId": true
  },
  "AllowedHosts": "*"
}
