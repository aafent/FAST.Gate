{
  "Gate": {
    "Identity": {
      "Provider": "logto",
      "Logto": {
        "IssuerUrl": "https://2uaw9x.logto.app/oidc",
        "ApiBaseUrl": "https://2uaw9x.logto.app",
        "Audience": "https://fast.gate.internal",
        "ServiceClientId": "PUT_YOUR_CLIENT_ID_HERE",
        "ServiceClientSecret": "PUT_YOUR_CLIENT_SECRET_HERE",
        "WebClientId": "PUT_YOUR_WEBCLIENT_ID_HERE",
        "WebClientSecret": "PUT_YOUR_WEBCLIENT_SECRET_HERE",
        "ServiceRedirectUri": "https://gate.fast.internal/auth/internal-callback",
        "JwksCacheTtlMs": 600000,
        "JwksFetchTimeoutMs": 3000,
        "JwksRetryAttempts": 3,
        "JwksRetryDelayMs": 500
      }
    },
    "Cache": {
      "TokenCacheEnabled": true,
      "TokenCacheMaxSize": 1000,
      "TokenCacheEarlyExpiryBufferMs": 10000
    },
    "Sso": {
      "AllowedRedirectUris": []
    },
    "Session": {
      "SessionLifetimeMinutes": 60,
      "RememberMeLifetimeDays": 30,
      "RefreshBufferSeconds": 60
    },
    "Logging": {
      "MinimumLevel": "Information",
      "RedactedFields": [
        "Password",
        "AccessToken",
        "RefreshToken"
      ]
    }
  },
  "AllowedRedirectUris": [
    "https://localhost:7002/auth/callback",
    "https://2uaw9x.logto.app/oidc/callback"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5040"
        }
      }
    }

}


